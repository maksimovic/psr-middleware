{
    "name": "maksimovic/psr-middleware",
    "description": "Foundational interface for PSR-7 middleware",
    "keywords": ["psr", "middleware"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {"Chadicus\\Psr\\Middleware\\" : "src"}
    },
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "test:coverage": "phpunit --coverage-text --coverage-html build/coverage --coverage-clover build/logs/clover.xml"
    }
}
